# Vedetta Environment Variables
# Copy to .env and fill in your values. Never commit .env itself.

# Backend
VEDETTA_PORT=8080
VEDETTA_DB_PATH=/data/vedetta.db
VEDETTA_FRONTEND_DIR=/frontend

# Network Scanning
VEDETTA_SCAN_CIDR=192.168.1.0/24
VEDETTA_SCAN_INTERVAL=5m
VEDETTA_SCAN_PORTS=false
VEDETTA_FRONTEND_PORT=3000

# Pi-hole Integration
PIHOLE_API_URL=http://pi.hole/admin/api.php
PIHOLE_API_TOKEN=

# Telemetry (opt-in only)
VEDETTA_TELEMETRY_OPTIN=false
VEDETTA_THREAT_NETWORK_URL=http://threat-network:9090
VEDETTA_INSTALL_SALT=

# Threat Network Backend
THREAT_NETWORK_PORT=9090
